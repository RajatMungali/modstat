{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "modswift25",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Open ModStat Dashboard",
        "description": "View weekly removal analytics",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Seed ModStat Demo Data",
        "description": "Load 4 weeks of realistic demo data (use before submitting)",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/seed-demo-data"
      }
    ]
  },
  "forms": {},
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onModAction": "/internal/triggers/on-mod-action",
    "onAutomoderatorFilterPost": "/internal/triggers/on-automoderator-filter-post"
  },
  "scheduler": {
    "tasks": {
      "weekly-digest": {
        "endpoint": "/internal/triggers/on-scheduler"
      }
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "modswift25_dev"
  }
}
